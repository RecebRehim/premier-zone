spring.application.name=premier-zone

# Comma-separated browser origins allowed to call the API (your React dev server or deployed site)
app.cors.allowed-origins=http://localhost:3000,http://127.0.0.1:3000

spring.datasource.url=jdbc:postgresql://localhost:5432/prem_stats
spring.datasource.username=postgres
spring.datasource.password=YOUR_PASSWORD_HERE

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true
